    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "joi": "^17.9.2",
    "morgan": "^1.10.0",
    "uuid": "^9.0.0",
    "winston": "^3.10.0",
    "winston-daily-rotate-file": "^4.7.1",
    "@supabase/supabase-js": "^2.33.0",
    "bull": "^4.11.3",
    "ioredis": "^5.3.2",
    "node-cron": "^3.0.2"
  },
  "devDependencies": {
    "jest": "^29.6.0",
